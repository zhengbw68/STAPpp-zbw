\begin_layout Subsubsection
基本原理
\end_layout

\begin_layout Standard
本梁单元为二节点三维 Euler-Bernoulli 等截面梁单元，
每个节点定义 6 个自由度 
\begin_inset Formula $(u_{x},u_{y},u_{z},\theta_{x},\theta_{y},\theta_{z})$
\end_inset

。
单元理论充分考虑了以下受力行为：
 
\end_layout

\begin_layout Itemize
轴向变形（拉压行为）；
 
\end_layout

\begin_layout Itemize
双向弯曲（分别位于 
\begin_inset Formula $xy$
\end_inset

 平面和 
\begin_inset Formula $xz$
\end_inset

 平面）；
 
\end_layout

\begin_layout Itemize
截面扭转。
 
\end_layout

\begin_layout Standard

\series bold
局部坐标系下的刚度系数
\series default
：

\begin_inset Newline newline
\end_inset

 假设单元纵轴沿 
\begin_inset Formula $x'$
\end_inset

 方向，

\begin_inset Formula $y'$
\end_inset

 和 
\begin_inset Formula $z'$
\end_inset

 分别对应截面的主轴方向。
其独立刚度系数定义如下：
 
\begin_inset Formula 
\begin{align*}
k_{1} & =\frac{EA}{L} & \text{（轴向刚度）}\\
k_{2} & =\frac{12EI_{z}}{L^{3}} & \text{（}y'\text{方向弯曲剪切刚度）}\\
k_{3} & =\frac{12EI_{y}}{L^{3}} & \text{（}z'\text{方向弯曲剪切刚度）}\\
k_{4} & =\frac{GI_{\mathrm{p}}}{L} & \text{（扭转刚度）}\\
k_{5} & =\frac{4EI_{y}}{L} & \text{（}z'\text{方向弯曲转动刚度）}\\
k_{6} & =\frac{4EI_{z}}{L} & \text{（}y'\text{方向弯曲转动刚度）}\\
k_{7} & =\frac{6EI_{y}}{L^{2}} & \text{（}z'\text{方向弯曲耦合刚度）}\\
k_{8} & =\frac{6EI_{z}}{L^{2}} & \text{（}y'\text{方向弯曲耦合刚度）}
\end{align*}

\end_inset

式中，

\begin_inset Formula $L$
\end_inset

 为单元长度；

\begin_inset Formula $E$
\end_inset

 为弹性模量；

\begin_inset Formula $G$
\end_inset

 为剪切模量；

\begin_inset Formula $I_{z}$
\end_inset

 和 
\begin_inset Formula $I_{y}$
\end_inset

 分别为绕 
\begin_inset Formula $z'$
\end_inset

 轴和 
\begin_inset Formula $y'$
\end_inset

 轴的截面惯性矩；

\begin_inset Formula $I_{\mathrm{p}}=I_{z}+I_{y}$
\end_inset

 为截面极惯性矩。

\end_layout

\begin_layout Standard
针对矩形箱形截面，
其惯性矩计算公式为：
 
\begin_inset Formula 
\begin{equation}
I_{z}=\frac{a^{3}b}{12}-\frac{(a-t_{1}-t_{3})^{3}(b-t_{2}-t_{4})}{12}
\end{equation}

\end_inset


\begin_inset Formula 
\begin{equation}
I_{y}=\frac{b^{3}a}{12}-\frac{(b-t_{2}-t_{4})^{3}(a-t_{1}-t_{3})}{12}
\end{equation}

\end_inset

式中，

\begin_inset Formula $a$
\end_inset

 为截面外围宽度，

\begin_inset Formula $b$
\end_inset

 为截面外围高度；

\begin_inset Formula $t_{1},t_{2},t_{3},t_{4}$
\end_inset

 分别为右、上、左、下侧壁厚。

\end_layout

\begin_layout Standard

\series bold
局部坐标到全局坐标的转换
\series default
：

\begin_inset Newline newline
\end_inset

 通过构建方向余弦矩阵 
\begin_inset Formula $\boldsymbol{n}_{3\times3}$
\end_inset

，
实现从局部坐标系 
\begin_inset Formula $(x',y',z')$
\end_inset

 到全局坐标系 
\begin_inset Formula $(x,y,z)$
\end_inset

 的转换：
 
\end_layout

\begin_layout Itemize
\begin_inset Formula $x'$
\end_inset

 方向：
单位矢量沿单元轴线方向 
\begin_inset Formula $\boldsymbol{n}_{0}=\Delta\boldsymbol{x}/L$
\end_inset

；
 
\end_layout

\begin_layout Itemize
\begin_inset Formula $y'$
\end_inset

 方向：
由用户输入指定的方向矢量 
\begin_inset Formula $(n_{1},n_{2},n_{3})$
\end_inset

 定义并正交化得到 
\begin_inset Formula $\boldsymbol{n}_{1}$
\end_inset

；
 
\end_layout

\begin_layout Itemize
\begin_inset Formula $z'$
\end_inset

 方向：
通过叉积求得 
\begin_inset Formula $\boldsymbol{n}_{2}=\boldsymbol{n}_{0}\times\boldsymbol{n}_{1}$
\end_inset

。
 
\end_layout

\begin_layout Standard
通过对空间旋转矩阵进行组装，
