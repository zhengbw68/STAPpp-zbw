\begin_layout Subsection
八节点六面体单元（8-Node Hexahedron Element，
Type 2）
\end_layout

\begin_layout Subsubsection
基本原理
\end_layout

\begin_layout Standard
八节点六面体实体单元（简称 8H 单元）为三维等参单元，
每个节点包含 3 个平动自由度 
\begin_inset Formula $(u_{x},u_{y},u_{z})$
\end_inset

，
单体总计 24 个自由度。

\end_layout

\begin_layout Standard

\series bold
形函数与等参变换
\series default
：

\begin_inset Newline newline
\end_inset

 在无量纲母单元局部坐标系 
\begin_inset Formula $(\xi,\eta,\zeta)\in[-1,1]^{3}$
\end_inset

 中，
8 个节点的形函数 
\begin_inset Formula $N_{i}$
\end_inset

 定义为：
 
\begin_inset Formula 
\begin{equation}
N_{i}(\xi,\eta,\zeta)=\frac{1}{8}(1+\xi_{i}\xi)(1+\eta_{i}\eta)(1+\zeta_{i}\zeta),\quad i=1,2,\dots,8
\end{equation}

\end_inset

式中 
\begin_inset Formula $(\xi_{i},\eta_{i},\zeta_{i})$
\end_inset

 为第 
\begin_inset Formula $i$
\end_inset

 个节点的局部自然坐标。
 通过等参变换建立母单元与物理空间域 
\begin_inset Formula $(x,y,z)$
\end_inset

 之间的映射：
 
\begin_inset Formula 
\begin{equation}
x=\sum^{8}_{i=1}N_{i}(\xi,\eta,\zeta)\,x_{i},\quad y=\sum^{8}_{i=1}N_{i}(\xi,\eta,\zeta)\,y_{i},\quad z=\sum^{8}_{i=1}N_{i}(\xi,\eta,\zeta)\,z_{i}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard

\series bold
雅可比矩阵与几何偏导数
\series default
：

\begin_inset Newline newline
\end_inset

 物理空间中的偏导数通过雅可比（Jacobi）矩阵 
\begin_inset Formula $\boldsymbol{J}$
\end_inset

 联系：
 
\begin_inset Formula 
\begin{equation}
\begin{Bmatrix}\frac{\partial N_{i}}{\partial x}\\[6pt]
\frac{\partial N_{i}}{\partial y}\\[6pt]
\frac{\partial N_{i}}{\partial z}
\end{Bmatrix}=\boldsymbol{J}^{-1}\begin{Bmatrix}\frac{\partial N_{i}}{\partial\xi}\\[6pt]
\frac{\partial N_{i}}{\partial\eta}\\[6pt]
\frac{\partial N_{i}}{\partial\zeta}
\end{Bmatrix}
\end{equation}

\end_inset

其中，
雅可比矩阵 
\begin_inset Formula $\boldsymbol{J}$
\end_inset

 定义为：
 
\begin_inset Formula 
\begin{equation}
\boldsymbol{J}=\begin{bmatrix}\frac{\partial x}{\partial\xi} & \frac{\partial y}{\partial\xi} & \frac{\partial z}{\partial\xi}\\[6pt]
\frac{\partial x}{\partial\eta} & \frac{\partial y}{\partial\eta} & \frac{\partial z}{\partial\eta}\\[6pt]
\frac{\partial x}{\partial\zeta} & \frac{\partial y}{\partial\zeta} & \frac{\partial z}{\partial\zeta}
\end{bmatrix}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard

\series bold
刚度矩阵构造
\series default
：

\begin_inset Newline newline
\end_inset

 由线弹性各向同性理论构造本构刚度矩阵 
\begin_inset Formula $\boldsymbol{D}$
\end_inset

，
基于应变-位移转换张量 
\begin_inset Formula $\boldsymbol{B}$
\end_inset

 建立单元刚度矩阵积分表达式，
并采用 
\begin_inset Formula $2\times2\times2$
\end_inset

 高斯积分方案（积分点坐标取值为 
\begin_inset Formula $\pm1/\sqrt{3}$
\end_inset

，
权重 
\begin_inset Formula $w_{p}=1$
\end_inset

）计算：
 
\begin_inset Formula 
\begin{equation}
\boldsymbol{k}^{(e)}=\sum^{8}_{p=1}\boldsymbol{B}^{\mathrm{T}}(\xi_{p},\eta_{p},\zeta_{p})\,\boldsymbol{D}\,\boldsymbol{B}(\xi_{p},\eta_{p},\zeta_{p})\ |\det\boldsymbol{J}(\xi_{p},\eta_{p},\zeta_{p})|\ w_{p}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard

\series bold
应力恢复与外推
\series default
：

\begin_inset Newline newline
\end_inset

 由于高斯点位置拥有最高的应力计算精度，
程序首先求解 8 个积分点的应力矢量 
\begin_inset Formula $\boldsymbol{\sigma}_{p}=\boldsymbol{D}\boldsymbol{B}\boldsymbol{u}^{(e)}$
\end_inset

，
随后通过形函数反算构造外推系数矩阵 
\begin_inset Formula $\boldsymbol{P}$
\end_inset

，
将应力外推至物理节点处输出：
 
\begin_inset Formula 
\begin{equation}
\boldsymbol{\sigma}_{\mathrm{node}}=\sum^{8}_{p=1}N^{\mathrm{extrap}}_{i}(\xi_{p},\eta_{p},\zeta_{p})\,\boldsymbol{\sigma}_{p}
\end{equation}

\end_inset


\end_layout

